# ─── Supabase ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# ─── Session JWT ───────────────────────────────────────────────────────────
# Any long random string (at least 32 chars)
JWT_SECRET=change-me-to-a-long-random-string-please

# ─── Email (Resend) ────────────────────────────────────────────────────────
# Leave blank in dev to log emails to stdout
RESEND_API_KEY=
MAIL_FROM="Crest Capital <noreply@crestcapital.com>"

# Optional — public base URL used inside emails
NEXT_PUBLIC_APP_URL=http://localhost:3000
